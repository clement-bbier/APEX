# APEX local secrets — copy to .env and replace with real values
# .env is gitignored — NEVER commit real keys

# ── FRED (St. Louis Fed) — Phase 2.7 ─────────────────────────────────────────
FRED_API_KEY=your_fred_api_key_here

# ── SimFin — Phase 2.9 ───────────────────────────────────────────────────
SIMFIN_API_KEY=your_simfin_api_key_here

# ── SEC EDGAR — Phase 2.9 ───────────────────────────────────────────────
EDGAR_USER_AGENT=APEX/CashMachine your_email@example.com

# ── Alpaca paper trading — Phase 2.5 ──────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=wss://stream.data.alpaca.markets/v2/iex

# ── Binance ───────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# ── Massive (ex-Polygon.io) — Phase 2.5 ──────────────────────────────────────
MASSIVE_API_KEY=your_massive_api_key_here
MASSIVE_S3_ACCESS_KEY=your_massive_s3_access_key_here
MASSIVE_S3_SECRET_KEY=your_massive_s3_secret_key_here
MASSIVE_S3_ENDPOINT=https://files.massive.com
MASSIVE_S3_BUCKET=flatfiles

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# APEX topology: an XSUB/XPUB broker (core/zmq_broker.py) binds both ports.
# Publishers CONNECT to ZMQ_PUB_PORT (XSUB facing). Subscribers CONNECT to
# ZMQ_SUB_PORT (XPUB facing). They MUST be different.
ZMQ_PUB_PORT=5555
ZMQ_SUB_PORT=5556
ZMQ_PUSH_PORT=5557
ZMQ_PULL_PORT=5557
ZMQ_HOST=127.0.0.1
TRADING_MODE=paper
MAX_DAILY_DRAWDOWN_PCT=0.03
MAX_POSITION_RISK_PCT=0.005
MAX_POSITION_SIZE_PCT=0.10
MAX_TOTAL_EXPOSURE_PCT=0.40
MAX_SIMULTANEOUS_POSITIONS=5
ALERT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_password
LOG_LEVEL=INFO
DASHBOARD_PORT=8080
DB_PASSWORD=apex_secret

# TimescaleDB
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=apex
TIMESCALE_USER=apex
TIMESCALE_PASSWORD=apex_secret
TIMESCALE_POOL_MIN=2
TIMESCALE_POOL_MAX=10

# Backtesting
BACKTEST_MODE=false
