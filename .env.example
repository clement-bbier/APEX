ALPACA_API_KEY=your_key
ALPACA_SECRET_KEY=your_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
BINANCE_API_KEY=your_key
BINANCE_SECRET_KEY=your_secret
FRED_API_KEY=your_key
REDIS_URL=redis://localhost:6379/0
# APEX topology: an XSUB/XPUB broker (core/zmq_broker.py) binds both ports.
# Publishers CONNECT to ZMQ_PUB_PORT (XSUB facing). Subscribers CONNECT to
# ZMQ_SUB_PORT (XPUB facing). They MUST be different.
ZMQ_PUB_PORT=5555
ZMQ_SUB_PORT=5556
ZMQ_PUSH_PORT=5557
ZMQ_PULL_PORT=5557
ZMQ_HOST=127.0.0.1
TRADING_MODE=paper
MAX_DAILY_DRAWDOWN_PCT=0.03
MAX_POSITION_RISK_PCT=0.005
MAX_POSITION_SIZE_PCT=0.10
MAX_TOTAL_EXPOSURE_PCT=0.40
MAX_SIMULTANEOUS_POSITIONS=5
ALERT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_password
LOG_LEVEL=INFO
DASHBOARD_PORT=8080
DB_PASSWORD=apex_secret

# Backtesting
BACKTEST_MODE=false
