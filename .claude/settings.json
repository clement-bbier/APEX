  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/protect_files.py",
            "timeout": 5,
            "statusMessage": "Checking file protection..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/ruff_check.py",
            "timeout": 15,
            "statusMessage": "Running ruff..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/pytest_calculator.py",
            "timeout": 60,
            "statusMessage": "Running calculator tests..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"REPO STATE: branch='$(git branch --show-current)' | last_commit='$(git log --oneline -1)' | uncommitted='$(git status --porcelain | wc -l | tr -d \" \")' files | modified_last_3_commits='$(git diff --name-only HEAD~3 2>/dev/null | head -10 | tr \"\n\" \",\" | sed \"s/,$//\")'\"}}'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
